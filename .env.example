# Groq API Configuration (keys start with gsk_)
GROQ_API_KEY=your_groq_api_key_here


# App settings
LOG_LEVEL=info
HOST=127.0.0.1
PORT=8000

# LLM model configuration (e.g. llama-3.3-70b-versatile, llama-3.1-8b-instant)
LLM_MODEL=llama-3.1-8b-instant

# Budget band thresholds on average cost for two
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# Path to the processed restaurant dataset
DATA_PATH=data/processed/restaurants.parquet
